      "isDeleted": false,
      "boundElements": [],
      "updated": 1770843614019,
      "link": null,
      "locked": false,
      "text": "Static: We use this for speed when there is no security.\n\nProtected: We use \"Fake Headers\" to trick the website into thinking our Python code is a human using a browser. This solves your Carrefour 403 error.\n\nDynamic: We use this when data only appears after a page \"spins\" or loads. It is slower but sees everything a human sees.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Static: We use this for speed when there is no security.\n\nProtected: We use \"Fake Headers\" to trick the website into thinking our Python code is a human using a browser. This solves your Carrefour 403 error.\n\nDynamic: We use this when data only appears after a page \"spins\" or loads. It is slower but sees everything a human sees.",
      "autoResize": true,
      "lineHeight": 1.35
    },
